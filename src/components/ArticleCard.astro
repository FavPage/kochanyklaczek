---
import { CATEGORIES } from '../lib/categories';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'blog'>;
}

const { article } = Astro.props;
const { title, description, category, image, imageAlt, readingTime, publishDate } = article.data;
const cat = CATEGORIES[category];

const dateFormatted = publishDate.toLocaleDateString('pl-PL', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---

<article class="group flex flex-col gap-5 cursor-pointer">
  <a href={`/blog/${article.id}`} class="flex flex-col gap-5">

    <div class="relative w-full aspect-[4/3] rounded-[20px] overflow-hidden bg-[#f1edec]">
      <img
        src={image}
        alt={imageAlt}
        width="600"
        height="450"
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        loading="lazy"
        decoding="async"
      />
      <div class="absolute top-4 left-4">
        <span class="inline-flex items-center px-3.5 py-1.5 bg-white/90 backdrop-blur-sm text-[#1c1b1b] font-['Plus_Jakarta_Sans'] text-[10px] font-bold tracking-[0.08em] uppercase rounded-full">
          {cat.label}
        </span>
      </div>
    </div>

    <div class="flex flex-col gap-2.5">
      <h2 class="font-['Plus_Jakarta_Sans'] text-[1.05rem] font-semibold text-[#1c1b1b] group-hover:text-[#3f2122] transition-colors line-clamp-2 leading-snug">
        {title}
      </h2>
      {description && (
        <p class="text-[#7e756f] line-clamp-2 leading-relaxed" style="font-family: 'Newsreader', serif; font-size: 1rem;">
          {description}
        </p>
      )}
      <div class="flex items-center gap-2 mt-1 text-[#7e756f] font-['Plus_Jakarta_Sans'] text-[10px] font-bold tracking-[0.08em] uppercase">
        <span>{readingTime} min czytania</span>
        <span aria-hidden="true">•</span>
        <time datetime={publishDate.toISOString()}>{dateFormatted}</time>
      </div>
    </div>

  </a>
</article>
