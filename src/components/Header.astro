---
import { CATEGORIES, SITE } from '../lib/categories';
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import { getCollection } from 'astro:content';

const currentPath = Astro.url.pathname;
const allPosts = await getCollection('blog', (a) => !a.data.draft);
const categoriesWithPosts = new Set(allPosts.map((a) => a.data.category));
const categories = Object.values(CATEGORIES).filter((cat) => categoriesWithPosts.has(cat.slug));
---

<header class="border-b border-[#E4E4E7] bg-[#FAFAFA]">
  <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between gap-6">

    <a href="/" class="flex items-center gap-2 shrink-0">
      <Image src={logo} alt={SITE.name} width={88} height={88} />
    </a>

    <nav aria-label="Główna nawigacja">
      <ul class="flex flex-wrap gap-x-5 gap-y-1 text-sm">
        {categories.map((cat) => {
          const isActive = currentPath.startsWith(`/kategoria/${cat.slug}`);
          return (
            <li>
              <a
                href={`/kategoria/${cat.slug}`}
                class={`transition-colors duration-150 hover:text-[#EC4899] ${
                  isActive ? 'text-[#EC4899] font-semibold' : 'text-[#71717A]'
                }`}
              >
                {cat.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

  </div>
</header>
