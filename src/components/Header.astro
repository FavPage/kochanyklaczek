---
import { CATEGORIES, SITE } from '../lib/categories';
import logo from '../assets/logo.png';

const currentPath = Astro.url.pathname;
const categories = Object.values(CATEGORIES);
---

<header class="border-b border-[#E4E4E7] bg-[#FAFAFA]">
  <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between gap-6">

    <a href="/" class="flex items-center gap-2 shrink-0">
      <img src={logo.src} alt={SITE.name} class="h-20 w-auto" />
    </a>

    <nav aria-label="Główna nawigacja">
      <ul class="flex flex-wrap gap-x-5 gap-y-1 text-sm">
        {categories.map((cat) => {
          const isActive = currentPath.startsWith(`/kategoria/${cat.slug}`);
          return (
            <li>
              <a
                href={`/kategoria/${cat.slug}`}
                class={`transition-colors duration-150 hover:text-[#EC4899] ${
                  isActive ? 'text-[#EC4899] font-semibold' : 'text-[#71717A]'
                }`}
              >
                {cat.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <a
      href="https://www.instagram.com/kochanyklaczek/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Instagram Kochany Kłaczek"
      class="shrink-0 text-[#71717A] hover:text-[#EC4899] transition-colors duration-150"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
        <circle cx="12" cy="12" r="4.5"/>
        <circle cx="17.5" cy="6.5" r="0.75" fill="currentColor" stroke="none"/>
      </svg>
    </a>

  </div>
</header>
