---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{filtered.length > 1 && (
  <nav aria-label="Spis treści" class="not-prose">
    <p class="text-xs font-semibold uppercase tracking-widest text-[#71717A] mb-3">
      Spis treści
    </p>
    <ol class="space-y-1">
      {filtered.map((h) => (
        <li class={h.depth === 3 ? 'pl-4' : ''}>
          <a
            href={`#${h.slug}`}
            class="text-sm text-[#71717A] hover:text-[#EC4899] transition-colors duration-150 leading-relaxed block"
          >
            {h.text}
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}
