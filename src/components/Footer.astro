---
import { CATEGORIES, SITE } from '../lib/categories';

const year = new Date().getFullYear();
const categories = Object.values(CATEGORIES);
---

<footer class="bg-[#f7f3f1] mt-20">
  <div class="max-w-[1200px] mx-auto px-6 md:px-8 py-16 flex flex-col md:flex-row justify-between items-start md:items-center gap-8">

    <div>
      <p class="font-['Plus_Jakarta_Sans'] text-base font-semibold text-[#2D2926] tracking-tight mb-1">
        {SITE.name}
      </p>
      <p class="text-sm text-[#7e756f]">© {year} Kochany Kłaczek</p>
    </div>

    <nav aria-label="Nawigacja stopki">
      <ul class="flex flex-wrap gap-x-8 gap-y-3 items-center">
        {categories.map((cat) => (
          <li>
            <a
              href={`/kategoria/${cat.slug}`}
              class="font-['Plus_Jakarta_Sans'] text-xs font-bold tracking-[0.08em] uppercase text-[#7e756f] hover:text-[#D4A373] transition-colors duration-200"
            >
              {cat.label}
            </a>
          </li>
        ))}
        <li>
          <a
            href="/o-nas"
            class="font-['Plus_Jakarta_Sans'] text-xs font-bold tracking-[0.08em] uppercase text-[#7e756f] hover:text-[#D4A373] transition-colors duration-200"
          >
            O nas
          </a>
        </li>
        <li>
          <a
            href="https://www.instagram.com/kochanyklaczek/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram Kochany Kłaczek"
            class="text-[#7e756f] hover:text-[#D4A373] transition-colors duration-200 flex items-center"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4.5"/>
              <circle cx="17.5" cy="6.5" r="0.75" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        </li>
      </ul>
    </nav>

  </div>
</footer>
