---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('blog', (a) => !a.data.draft);
const sorted = allArticles.sort((a, b) =>
  b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<BaseLayout
  title="Wszystkie artykuły"
  description="Artykuły o kotach — żywienie, zdrowie, zachowanie, akcesoria i nowy kot w domu."
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="font-['Instrument_Serif'] text-4xl text-[#18181B] mb-10">Wszystkie artykuły</h1>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {sorted.map((article) => (
        <ArticleCard article={article} />
      ))}
    </div>
  </div>
</BaseLayout>
