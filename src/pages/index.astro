---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { CATEGORIES, SITE } from '../lib/categories';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('blog', (a) => !a.data.draft);
const sorted = allArticles.sort((a, b) =>
  b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
const featured = sorted[0];
const recent = sorted.slice(1, 7);
const categories = Object.values(CATEGORIES);

const categoryIcons: Record<string, string> = {
  zywienie: 'restaurant',
  zdrowie: 'health_and_safety',
  zachowanie: 'psychology',
  'nowy-pupil': 'pets',
  akcesoria: 'shopping_bag',
};
---

<BaseLayout
  title="Blog o psach i kotach - żywienie, zdrowie, zachowanie"
  description={SITE.description}
>

  <!-- 1. Hero -->
  <section class="max-w-[1200px] mx-auto px-4 md:px-8 pt-20 pb-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">

      <div class="lg:col-span-6 space-y-8 lg:pr-12">
        <h1 class="font-['Plus_Jakarta_Sans'] text-4xl sm:text-5xl font-bold tracking-tight text-[#1c1b1b] leading-[1.1]">
          Mądrze, ciepło i bez paniki — wszystko o życiu z psem i kotem
        </h1>
        <p class="text-xl text-[#4d4540] max-w-xl leading-relaxed" style="font-family: 'Newsreader', serif;">
          Praktyczne poradniki, ciekawostki i spokojne odpowiedzi na pytania, które zna każdy opiekun pupila.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 pt-2">
          <a
            href="/blog"
            class="inline-flex justify-center items-center px-8 py-4 bg-[#ecbbba] text-[#3f2122] text-xs font-bold font-['Plus_Jakarta_Sans'] tracking-[0.08em] uppercase rounded-full hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300"
          >
            Czytaj poradniki
          </a>
          <a
            href="/o-nas"
            class="inline-flex justify-center items-center px-8 py-4 bg-transparent border border-[#cfc4bd] text-[#1c1b1b] text-xs font-bold font-['Plus_Jakarta_Sans'] tracking-[0.08em] uppercase rounded-full hover:bg-[#f1edec] transition-all duration-300"
          >
            Poznaj Kochany Kłaczek
          </a>
        </div>
      </div>

      {featured && (
        <div class="lg:col-span-6 mt-4 lg:mt-0">
          <a
            href={`/blog/${featured.id}`}
            class="group block relative w-full aspect-[4/3] rounded-[24px] overflow-hidden shadow-[0_40px_80px_rgba(45,41,38,0.08)]"
          >
            <img
              src={featured.data.image}
              alt={featured.data.imageAlt}
              class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
              loading="eager"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[rgba(28,27,27,0.65)] via-transparent to-transparent flex items-end p-7">
              <div>
                <span class="text-[10px] font-bold font-['Plus_Jakarta_Sans'] tracking-[0.12em] uppercase text-[#ecbbba] block mb-2">
                  {CATEGORIES[featured.data.category].label}
                </span>
                <h2 class="text-white font-['Plus_Jakarta_Sans'] text-xl font-semibold leading-snug">
                  {featured.data.title}
                </h2>
              </div>
            </div>
          </a>
        </div>
      )}

    </div>
  </section>

  <!-- 2. Kategorie (Bento) -->
  <section class="bg-[#f7f3f1] py-20">
    <div class="max-w-[1200px] mx-auto px-4 md:px-8">
      <div class="mb-10">
        <h2 class="font-['Plus_Jakarta_Sans'] text-3xl font-semibold tracking-tight text-[#1c1b1b] mb-3">
          Eksploruj świat psów i kotów
        </h2>
        <p class="text-[#4d4540] text-lg" style="font-family: 'Newsreader', serif;">
          Wybierz temat, który Cię interesuje.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
        {categories.map((cat) => {
          const isWide = cat.slug === 'zywienie' || cat.slug === 'nowy-pupil' || cat.slug === 'akcesoria';
          return (
            <a
              href={`/kategoria/${cat.slug}`}
              class={`group flex flex-col justify-between p-8 bg-white rounded-[20px] shadow-[0_20px_50px_rgba(45,41,38,0.03)] hover:shadow-[0_30px_60px_rgba(45,41,38,0.07)] hover:-translate-y-1 transition-all duration-300 ${isWide ? 'lg:col-span-2' : ''}`}
            >
              <div class="w-12 h-12 rounded-full bg-[#f1edec] flex items-center justify-center text-[#4d4540] mb-6">
                <span class="material-symbols-outlined text-2xl">{categoryIcons[cat.slug]}</span>
              </div>
              <div>
                <h3 class="font-['Plus_Jakarta_Sans'] text-xl font-semibold text-[#1c1b1b] mb-2 group-hover:text-[#3f2122] transition-colors">
                  {cat.label}
                </h3>
                <p class="text-[#7e756f] line-clamp-2" style="font-family: 'Newsreader', serif;">
                  {cat.description}
                </p>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 3. Najnowsze artykuły -->
  {recent.length > 0 && (
    <section class="max-w-[1200px] mx-auto px-4 md:px-8 py-20">
      <div class="flex justify-between items-center mb-10">
        <h2 class="font-['Plus_Jakarta_Sans'] text-3xl font-semibold tracking-tight text-[#1c1b1b]">
          Najnowsze artykuły
        </h2>
        <a
          href="/blog"
          class="font-['Plus_Jakarta_Sans'] text-xs font-bold tracking-[0.08em] uppercase text-[#4d4540] hover:text-[#D4A373] transition-colors flex items-center gap-2"
        >
          Wszystkie
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {recent.map((article) => (
          <ArticleCard article={article} />
        ))}
      </div>
    </section>
  )}

  <!-- 4. Trust Section -->
  <section class="bg-[#ebe1d4] py-20">
    <div class="max-w-[1200px] mx-auto px-4 md:px-8 text-center">
      <h2 class="font-['Plus_Jakarta_Sans'] text-3xl font-semibold tracking-tight text-[#1c1b1b] mb-16 max-w-2xl mx-auto">
        Spokojne poradniki dla opiekunów. Bez paniki, z wiedzą.
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="flex flex-col items-center">
          <div class="w-14 h-14 rounded-full bg-white flex items-center justify-center text-[#4d4540] mb-5 shadow-[0_10px_30px_rgba(45,41,38,0.05)]">
            <span class="material-symbols-outlined text-2xl">record_voice_over</span>
          </div>
          <h3 class="font-['Plus_Jakarta_Sans'] text-lg font-semibold text-[#1c1b1b] mb-2">Prosty język</h3>
          <p class="text-[#4d4540] max-w-xs" style="font-family: 'Newsreader', serif;">
            Tłumaczymy kocie i psie sprawy na zrozumiały język — bez zbędnego żargonu.
          </p>
        </div>
        <div class="flex flex-col items-center">
          <div class="w-14 h-14 rounded-full bg-white flex items-center justify-center text-[#4d4540] mb-5 shadow-[0_10px_30px_rgba(45,41,38,0.05)]">
            <span class="material-symbols-outlined text-2xl">check_circle</span>
          </div>
          <h3 class="font-['Plus_Jakarta_Sans'] text-lg font-semibold text-[#1c1b1b] mb-2">Praktyczne wskazówki</h3>
          <p class="text-[#4d4540] max-w-xs" style="font-family: 'Newsreader', serif;">
            Konkretne rozwiązania problemów, które możesz zastosować już dziś.
          </p>
        </div>
        <div class="flex flex-col items-center">
          <div class="w-14 h-14 rounded-full bg-white flex items-center justify-center text-[#4d4540] mb-5 shadow-[0_10px_30px_rgba(45,41,38,0.05)]">
            <span class="material-symbols-outlined text-2xl">menu_book</span>
          </div>
          <h3 class="font-['Plus_Jakarta_Sans'] text-lg font-semibold text-[#1c1b1b] mb-2">Oparte na źródłach</h3>
          <p class="text-[#4d4540] max-w-xs" style="font-family: 'Newsreader', serif;">
            Czerpiemy z wiedzy behawiorystów i aktualnej literatury weterynaryjnej.
          </p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
